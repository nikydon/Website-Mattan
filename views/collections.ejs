<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>
  <section class="section">
    <h1 class="page-title">Collections</h1>

    <% if (collections.length) { %>
    <div class="grid grid-4">
      <% collections.forEach(col => { %>
      <a href="/collections/<%= col.slug %>" class="card">
        <% if (col.catalogItems.length && col.catalogItems[0].images.length) { %>
          <div class="card-img" style="background-image: url('/uploads/thumbs/<%= col.catalogItems[0].images[0].filename.replace(/\.\w+$/, '.webp') %>')"></div>
        <% } else { %>
          <div class="card-img card-img--empty"></div>
        <% } %>
        <h3 class="card-title"><%= col.name %></h3>
        <% if (col.description) { %>
          <p class="card-desc"><%= col.description %></p>
        <% } %>
        <p class="card-count"><%= col._count.catalogItems %> piece<%= col._count.catalogItems !== 1 ? 's' : '' %></p>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <p class="empty-state">No collections yet.</p>
    <% } %>
  </section>
</main>

<%- include('partials/footer') %>
