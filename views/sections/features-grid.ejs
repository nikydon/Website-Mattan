<%
  var c = (typeof sectionContent !== 'undefined' && sectionContent['features-grid']) || {};
  var heading = c.heading || '';
  var items = [];
  try { items = c.items ? JSON.parse(c.items) : []; } catch(e) {}
  if (!items.length) {
    items = [
      { title: 'Handcrafted', description: 'Each piece is carefully made by skilled artisans.' },
      { title: 'Sustainable', description: 'We use ethically sourced, eco-friendly materials.' },
      { title: 'Timeless Design', description: 'Classic aesthetics that transcend fleeting trends.' },
      { title: 'Free Shipping', description: 'Complimentary delivery on orders over a certain amount.' }
    ];
  }
%>
<section class="section features-grid-section">
  <% if (heading) { %>
    <h2 class="section-title" data-editable="heading"><%= heading %></h2>
  <% } %>
  <div class="features-grid">
    <% items.forEach(function(item) { %>
    <div class="feature-card">
      <h3 class="feature-title"><%= item.title %></h3>
      <p class="feature-desc"><%= item.description %></p>
    </div>
    <% }); %>
  </div>
</section>
