<aside class="admin-sidebar" id="adminSidebar">
  <div class="admin-sidebar-header">
    <a href="/admin" class="admin-brand">
      <span>MATTAN</span>
    </a>
    <button class="sidebar-toggle" onclick="toggleSidebar()" title="Toggle sidebar">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 19l-7-7 7-7M18 19l-7-7 7-7"/></svg>
    </button>
  </div>

  <nav class="admin-nav">
    <div class="nav-section">
      <span class="nav-section-label">Main</span>
      <a href="/admin" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"/></svg>
        <span>Dashboard</span>
      </a>
      <a href="/admin/analytics" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'analytics' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6m6 0h6m-6 0V9a2 2 0 012-2h2a2 2 0 012 2v10m6 0v-4a2 2 0 00-2-2h-2a2 2 0 00-2 2v4"/></svg>
        <span>Analytics</span>
      </a>
    </div>

    <div class="nav-section">
      <span class="nav-section-label">Catalog</span>
      <a href="/admin/collections" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'collections' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        <span>Collections</span>
      </a>
      <a href="/admin/items" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'items' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        <span>Products</span>
      </a>
      <a href="/admin/media" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'media' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span>Media</span>
      </a>
    </div>

    <div class="nav-section">
      <span class="nav-section-label">Commerce</span>
      <a href="/admin/orders" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'orders' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        <span>Orders</span>
        <% if (typeof orderCount !== 'undefined' && orderCount > 0) { %>
          <span class="admin-nav-badge"><%= orderCount %></span>
        <% } %>
      </a>
      <a href="/admin/customers" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'customers' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span>Customers</span>
      </a>
      <a href="/admin/coupons" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'coupons' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
        <span>Coupons</span>
      </a>
    </div>

    <div class="nav-section">
      <span class="nav-section-label">Content</span>
      <a href="/admin/news" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'news' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        <span>News</span>
      </a>
      <a href="/admin/layout" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'layout' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
        <span>Layout Editor</span>
      </a>
    </div>

    <div class="nav-section">
      <span class="nav-section-label">System</span>
      <a href="/admin/settings" class="admin-nav-link<%= typeof activePage !== 'undefined' && activePage === 'settings' ? ' active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
        <span>Settings</span>
      </a>
    </div>
  </nav>

  <div class="admin-sidebar-footer">
    <div class="admin-nav-link theme-toggle" onclick="toggleTheme()">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      <span>Dark Mode</span>
      <button class="theme-switch" type="button" aria-label="Toggle dark mode"></button>
    </div>
    <a href="/" class="admin-nav-link" target="_blank">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      <span>View Store</span>
    </a>
    <form action="/admin/logout" method="POST" style="display:contents">
      <button type="submit" class="admin-nav-link admin-logout-btn">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        <span>Log Out</span>
      </button>
    </form>
  </div>
</aside>
