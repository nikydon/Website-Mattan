    <div class="stat-card">
      <span class="stat-number"><%= counts.videos %></span>
      <span class="stat-label">Videos</span>
    </div>
    <div class="stat-card">
      <span class="stat-number"><%= counts.posts %></span>
      <span class="stat-label">News Posts</span>
    </div>
