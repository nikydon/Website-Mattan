<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <span class="current">Dashboard</span>
  </div>

  <div class="admin-header-row">
    <h1 class="admin-page-title">Dashboard</h1>
    <span class="muted" style="font-size:0.85rem">Welcome back</span>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-card-icon blue">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
      <span class="stat-number"><%= counts.items %></span>
      <span class="stat-label">Products</span>
    </div>
    <div class="stat-card">
      <div class="stat-card-icon green">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </div>
      <span class="stat-number"><%= counts.collections %></span>
      <span class="stat-label">Collections</span>
    </div>
    <div class="stat-card">
      <div class="stat-card-icon orange">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      </div>
      <span class="stat-number"><%= counts.orders %></span>
      <span class="stat-label">Orders</span>
    </div>
    <div class="stat-card">
      <div class="stat-card-icon red">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </div>
      <span class="stat-number"><%= counts.customers %></span>
      <span class="stat-label">Customers</span>
    </div>
    <div class="stat-card">
      <div class="stat-card-icon blue">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <span class="stat-number"><%= counts.images %></span>
      <span class="stat-label">Media Files</span>
    </div>
  </div>

  <div class="dashboard-grid">
    <!-- Revenue Chart -->
    <div class="chart-container">
      <div class="chart-header">
        <h3 class="chart-title">Revenue Overview</h3>
        <div class="filter-group">
          <button class="btn btn--small btn--primary">30 Days</button>
          <button class="btn btn--small">90 Days</button>
        </div>
      </div>
      <div class="chart-area">
        <% [40,55,35,70,60,80,45,90,65,50,75,85,55,70,60,95,50,65,80,70,55,90,75,60,85,70,55,80,65,90].forEach(function(h) { %>
          <div class="chart-bar" style="height:<%= h %>%"></div>
        <% }); %>
      </div>
      <div class="chart-labels"><span>Mar 1</span><span>Mar 8</span><span>Mar 15</span><span>Mar 22</span><span>Today</span></div>
    </div>

    <div>
      <!-- Low Stock Alerts -->
      <div class="card mb-2">
        <div class="card-header">
          <h3 class="card-title">Low Stock Alerts</h3>
          <span class="badge badge--warning"><%= lowStock.length %></span>
        </div>
        <div class="card-body">
          <% if (lowStock.length === 0) { %>
            <p class="muted" style="font-size:0.85rem">All products are well-stocked.</p>
          <% } else { %>
            <ul class="top-products-list">
              <% lowStock.forEach(function(item) { %>
              <li class="top-product-item">
                <div class="top-product-info">
                  <div class="top-product-name"><%= item.title %></div>
                  <div class="top-product-detail"><%= item.collection ? item.collection.name : 'Uncategorized' %></div>
                </div>
                <span class="badge badge--danger"><%= item.stockQty %> left</span>
              </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Recent Activity</h3>
        </div>
        <div class="card-body">
          <ul class="activity-list">
            <% recentItems.slice(0, 4).forEach(function(item) { %>
            <li class="activity-item">
              <span class="activity-dot blue"></span>
              <span class="activity-text"><strong><%= item.title %></strong> updated</span>
              <span class="activity-time"><%= new Date(item.updatedAt).toLocaleDateString('en-GB', {day:'numeric',month:'short'}) %></span>
            </li>
            <% }); %>
            <% recentPosts.slice(0, 3).forEach(function(post) { %>
            <li class="activity-item">
              <span class="activity-dot green"></span>
              <span class="activity-text"><strong><%= post.title %></strong> <%= post.publishedAt ? 'published' : 'drafted' %></span>
              <span class="activity-time"><%= new Date(post.updatedAt).toLocaleDateString('en-GB', {day:'numeric',month:'short'}) %></span>
            </li>
            <% }); %>
            <% if (!recentItems.length && !recentPosts.length) { %>
            <li class="activity-item"><span class="activity-text muted">No recent activity.</span></li>
            <% } %>
          </ul>
        </div>
      </div>
    </div>

    <!-- Products Table -->
    <div class="card dashboard-full">
      <div class="card-header">
        <h3 class="card-title">Product Catalog</h3>
        <a href="/admin/items" class="btn btn--small">View All</a>
      </div>
      <div class="card-body--flush">
        <table class="admin-table" style="border:none">
          <thead><tr><th>Product</th><th>Collection</th><th>Price</th><th>Stock</th><th>Status</th></tr></thead>
          <tbody>
            <% recentItems.slice(0, 5).forEach(function(item) { %>
            <tr>
              <td><a href="/admin/items/<%= item.id %>/edit"><%= item.title %></a></td>
              <td class="muted"><%= item.collection ? item.collection.name : '-' %></td>
              <td><%= item.price || '-' %></td>
              <td><%= item.stockQty %></td>
              <td><span class="badge badge--<%= item.published ? 'success' : 'neutral' %>"><%= item.published ? 'Live' : 'Draft' %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
