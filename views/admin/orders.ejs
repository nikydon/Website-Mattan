<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <a href="/admin">Dashboard</a>
    <span class="sep">/</span>
    <span class="current">Orders</span>
  </div>

  <div class="admin-header-row">
    <h1 class="admin-page-title">Orders</h1>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <p class="flash flash--success"><%= flash %></p>
  <% } %>

  <div class="table-toolbar">
    <div class="search-box">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" id="ordersSearch" placeholder="Search orders..." autocomplete="off">
    </div>
    <div class="filter-group">
      <a href="/admin/orders" class="btn btn--small <%= !statusFilter ? 'btn--primary' : '' %>">All</a>
      <a href="/admin/orders?status=pending" class="btn btn--small <%= statusFilter === 'pending' ? 'btn--primary' : '' %>">Pending</a>
      <a href="/admin/orders?status=confirmed" class="btn btn--small <%= statusFilter === 'confirmed' ? 'btn--primary' : '' %>">Confirmed</a>
      <a href="/admin/orders?status=shipped" class="btn btn--small <%= statusFilter === 'shipped' ? 'btn--primary' : '' %>">Shipped</a>
      <a href="/admin/orders?status=delivered" class="btn btn--small <%= statusFilter === 'delivered' ? 'btn--primary' : '' %>">Delivered</a>
      <a href="/admin/orders?status=cancelled" class="btn btn--small <%= statusFilter === 'cancelled' ? 'btn--primary' : '' %>">Cancelled</a>
    </div>
  </div>

  <% if (orders.length) { %>
  <table class="admin-table" id="ordersTable">
    <thead>
      <tr>
        <th class="sortable">Order <span class="sort-icon">&#8597;</span></th>
        <th class="sortable">Customer <span class="sort-icon">&#8597;</span></th>
        <th>Items</th>
        <th class="sortable">Total <span class="sort-icon">&#8597;</span></th>
        <th>Status</th>
        <th class="sortable">Date <span class="sort-icon">&#8597;</span></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(function(order) { %>
      <tr>
        <td><strong>#<%= order.id.slice(0,8).toUpperCase() %></strong></td>
        <td><%= order.customer ? (order.customer.name || order.customer.email) : 'Guest' %></td>
        <td><%= order.items ? order.items.length : 0 %></td>
        <td><%= order.total || '-' %></td>
        <td>
          <% var statusClass = {pending:'warning',confirmed:'info',shipped:'info',delivered:'success',cancelled:'danger'}[order.status] || 'neutral'; %>
          <span class="badge badge--<%= statusClass %>"><span class="badge-dot"></span> <%= order.status %></span>
        </td>
        <td class="muted"><%= new Date(order.createdAt).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) %></td>
        <td class="actions-cell">
          <form method="POST" action="/admin/orders/<%= order.id %>/status" style="display:inline">
            <select name="status" class="form-input" style="width:auto;padding:0.25rem 0.5rem;font-size:0.75rem" onchange="this.form.submit()">
              <option value="">Update...</option>
              <option value="pending">Pending</option>
              <option value="confirmed">Confirmed</option>
              <option value="shipped">Shipped</option>
              <option value="delivered">Delivered</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>

  <div class="pagination" id="ordersTable-pagination">
    <span class="pagination-info"></span>
    <div class="pagination-buttons"></div>
  </div>
  <% } else { %>
  <div class="empty-state">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
    <h3 class="empty-state-title">No orders yet</h3>
    <p class="empty-state-text">Orders will appear here when customers make purchases.</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
<script>
  initTableSearch('ordersSearch', 'ordersTable');
  initTableSort('ordersTable');
  initPagination('ordersTable', 15);
</script>
