<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <a href="/admin">Dashboard</a>
    <span class="sep">/</span>
    <span class="current">Customers</span>
  </div>

  <div class="admin-header-row">
    <h1 class="admin-page-title">Customers</h1>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <p class="flash flash--success"><%= flash %></p>
  <% } %>

  <div class="table-toolbar">
    <div class="search-box">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" id="custSearch" placeholder="Search customers..." autocomplete="off">
    </div>
    <span class="muted" style="font-size:0.8rem"><%= customers.length %> customers</span>
  </div>

  <% if (customers.length) { %>
  <table class="admin-table" id="custTable">
    <thead>
      <tr>
        <th class="sortable">Name <span class="sort-icon">&#8597;</span></th>
        <th class="sortable">Email <span class="sort-icon">&#8597;</span></th>
        <th>Phone</th>
        <th class="sortable">Orders <span class="sort-icon">&#8597;</span></th>
        <th>Status</th>
        <th class="sortable">Joined <span class="sort-icon">&#8597;</span></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% customers.forEach(function(cust) { %>
      <tr>
        <td><strong><%= cust.name || '-' %></strong></td>
        <td><%= cust.email %></td>
        <td class="muted"><%= cust.phone || '-' %></td>
        <td><%= cust._count.orders %></td>
        <td>
          <% if (cust.flagged) { %>
            <span class="badge badge--danger">Flagged</span>
          <% } else { %>
            <span class="badge badge--success">Active</span>
          <% } %>
        </td>
        <td class="muted"><%= new Date(cust.createdAt).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) %></td>
        <td class="actions-cell">
          <form method="POST" action="/admin/customers/<%= cust.id %>/toggle-flag" style="display:inline">
            <button type="submit" class="btn btn--small <%= cust.flagged ? 'btn--success' : 'btn--danger' %>"><%= cust.flagged ? 'Unflag' : 'Flag' %></button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>

  <div class="pagination" id="custTable-pagination">
    <span class="pagination-info"></span>
    <div class="pagination-buttons"></div>
  </div>
  <% } else { %>
  <div class="empty-state">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    <h3 class="empty-state-title">No customers yet</h3>
    <p class="empty-state-text">Customers will appear here when they create accounts.</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
<script>
  initTableSearch('custSearch', 'custTable');
  initTableSort('custTable');
  initPagination('custTable', 15);
</script>
