<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <a href="/admin">Dashboard</a>
    <span class="sep">/</span>
    <span class="current">Media Library</span>
  </div>

  <div class="admin-header-row">
    <h1 class="admin-page-title">Media Library</h1>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <p class="flash flash--success"><%= flash %></p>
  <% } %>

  <form method="POST" action="/admin/media/upload" enctype="multipart/form-data" class="media-upload-bar">
    <input type="file" name="file" accept="image/*,video/mp4,video/webm,video/quicktime" required class="form-input" style="flex:1">
    <input type="text" name="altText" placeholder="Alt text / caption" class="form-input" style="flex:1">
    <select name="category" class="form-input" style="width:auto">
      <option value="general">General</option>
      <option value="catalog">Catalog</option>
      <option value="news">News</option>
    </select>
    <button type="submit" class="btn btn--primary">Upload</button>
  </form>

  <div class="media-filters">
    <a href="/admin/media" class="btn btn--small <%= filter === 'all' ? 'btn--primary' : '' %>">All</a>
    <a href="/admin/media?type=image" class="btn btn--small <%= filter === 'image' ? 'btn--primary' : '' %>">Images</a>
    <a href="/admin/media?type=video" class="btn btn--small <%= filter === 'video' ? 'btn--primary' : '' %>">Videos</a>
    <span class="muted" style="margin-left:0.5rem"><%= media.length %> file<%= media.length !== 1 ? 's' : '' %></span>
  </div>

  <% if (media.length) { %>
  <div class="media-grid">
    <% media.forEach(function(m) { %>
    <div class="media-card">
      <% if (m.mediaType === 'video') { %>
        <div class="media-thumb media-thumb--video">
          <video src="/uploads/full/<%= m.filename %>" muted preload="metadata"></video>
          <span class="media-badge">VIDEO</span>
        </div>
      <% } else { %>
        <div class="media-thumb">
          <img src="/uploads/thumbs/<%= m.filename.replace(/\.\w+$/, '.webp') %>" alt="<%= m.altText || m.originalName %>">
        </div>
      <% } %>
      <div class="media-card-info">
        <span class="media-card-name" title="<%= m.originalName %>"><%= m.originalName %></span>
        <span class="muted" style="font-size:0.7rem">
          <%= m.category %>
          <% if (m.catalogItem) { %> &middot; <%= m.catalogItem.title %><% } %>
          <% if (m.newsPost) { %> &middot; <%= m.newsPost.title %><% } %>
        </span>
      </div>
      <form method="POST" action="/admin/media/<%= m.id %>/delete" class="media-card-actions" onsubmit="return confirmDelete(this, 'Delete Media', 'Are you sure you want to delete this file?')">
        <button type="submit" class="btn btn--danger btn--small">Delete</button>
      </form>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="empty-state">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    <h3 class="empty-state-title">No media files yet</h3>
    <p class="empty-state-text">Upload your first photo or video above.</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
