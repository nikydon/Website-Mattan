<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <a href="/admin">Dashboard</a>
    <span class="sep">/</span>
    <a href="/admin/collections">Collections</a>
    <span class="sep">/</span>
    <span class="current"><%= isEdit ? collection.name : 'New Collection' %></span>
  </div>

  <h1 class="admin-page-title"><%= isEdit ? 'Edit' : 'New' %> Collection</h1>

  <form method="POST" action="<%= isEdit ? '/admin/collections/' + collection.id + '/edit' : '/admin/collections/new' %>" class="admin-form">
    <div class="form-row">
      <div>
        <label class="form-label" for="name">Name</label>
        <input class="form-input" type="text" id="name" name="name" value="<%= isEdit ? collection.name : '' %>" required>
      </div>
      <div>
        <label class="form-label" for="slug">Slug</label>
        <input class="form-input" type="text" id="slug" name="slug" value="<%= isEdit ? collection.slug : '' %>" required>
      </div>
    </div>

    <label class="form-label" for="description">Description</label>
    <textarea class="form-input form-textarea" id="description" name="description" rows="3"><%= isEdit && collection.description ? collection.description : '' %></textarea>

    <label class="form-label" for="sortOrder">Sort Order</label>
    <input class="form-input" type="number" id="sortOrder" name="sortOrder" value="<%= isEdit ? collection.sortOrder : 0 %>" style="max-width:120px">

    <label class="form-checkbox">
      <input type="checkbox" name="published" value="true" <%= isEdit && collection.published ? 'checked' : '' %>>
      Published
    </label>

    <div class="form-actions">
      <button class="btn btn--primary" type="submit">Save Collection</button>
      <a href="/admin/collections" class="btn">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
