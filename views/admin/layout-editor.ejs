    <div class="le-modal-body">
      <div class="le-shortcut-list">
        <div class="le-shortcut-item"><kbd>Ctrl+Z</kbd><span>Undo</span></div>
        <div class="le-shortcut-item"><kbd>Ctrl+Y</kbd><span>Redo</span></div>
        <div class="le-shortcut-item"><kbd>Ctrl+S</kbd><span>Save Draft</span></div>
        <div class="le-shortcut-item"><kbd>Ctrl+Shift+P</kbd><span>Publish</span></div>
        <div class="le-shortcut-item"><kbd>Ctrl+D</kbd><span>Duplicate Section</span></div>
        <div class="le-shortcut-item"><kbd>Delete</kbd><span>Delete Section</span></div>
        <div class="le-shortcut-item"><kbd>Ctrl+&uarr;</kbd><span>Move Section Up</span></div>
        <div class="le-shortcut-item"><kbd>Ctrl+&darr;</kbd><span>Move Section Down</span></div>
        <div class="le-shortcut-item"><kbd>Escape</kbd><span>Deselect</span></div>
        <div class="le-shortcut-item"><kbd>?</kbd><span>Show Shortcuts</span></div>
      </div>
    </div>
  </div>
</div>

