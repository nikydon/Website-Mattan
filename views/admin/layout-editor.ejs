<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <a href="/admin">Dashboard</a>
    <span class="sep">/</span>
    <span class="current">Layout Editor</span>
  </div>

  <div class="admin-header-row">
    <h1 class="admin-page-title">Layout Editor</h1>
    <div class="btn-group">
      <button class="btn" onclick="resetLayout()">Reset to Default</button>
      <button class="btn btn--primary" onclick="saveLayout()">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
        Save & Publish
      </button>
    </div>
  </div>

  <div class="layout-editor">
    <!-- Blocks Panel -->
    <div class="layout-blocks-panel">
      <h3 class="layout-blocks-title">Available Blocks</h3>

      <div class="layout-block-item" draggable="true" data-block="hero">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5z"/></svg>
        Hero Banner
      </div>
      <div class="layout-block-item" draggable="true" data-block="featured-products">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        Featured Products
      </div>
      <div class="layout-block-item" draggable="true" data-block="collections-grid">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        Collections Grid
      </div>
      <div class="layout-block-item" draggable="true" data-block="banner">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Image Banner
      </div>
      <div class="layout-block-item" draggable="true" data-block="text-block">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
        Text Block
      </div>
      <div class="layout-block-item" draggable="true" data-block="newsletter">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Newsletter Signup
      </div>
      <div class="layout-block-item" draggable="true" data-block="news-feed">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"/></svg>
        Latest News
      </div>
      <div class="layout-block-item" draggable="true" data-block="brand-story">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        Brand Story
      </div>
    </div>

    <!-- Canvas -->
    <div class="layout-canvas" id="layoutCanvas">
      <% if (sections.length === 0) { %>
      <div class="layout-canvas-empty" id="canvasEmpty">
        Drag blocks here to build your storefront layout
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
var sections = <%- JSON.stringify(sections) %>;
var blockLabels = {
  'hero': 'Hero Banner',
  'featured-products': 'Featured Products',
  'collections-grid': 'Collections Grid',
  'banner': 'Image Banner',
  'text-block': 'Text Block',
  'newsletter': 'Newsletter Signup',
  'news-feed': 'Latest News',
  'brand-story': 'Brand Story'
};
var blockPreviews = {
  'hero': 'Full-width hero with headline, tagline, and CTA button',
  'featured-products': 'Grid of featured/highlighted products',
  'collections-grid': 'Grid showing all collections with images',
  'banner': 'Full-width promotional image or campaign banner',
  'text-block': 'Rich text content area for brand messaging',
  'newsletter': 'Email signup form with heading and description',
  'news-feed': 'Latest news posts in a card layout',
  'brand-story': 'Brand story section with text and imagery'
};

var canvas = document.getElementById('layoutCanvas');
var dragSrcEl = null;

function renderSections() {
  canvas.innerHTML = '';
  if (sections.length === 0) {
    canvas.innerHTML = '<div class="layout-canvas-empty" id="canvasEmpty">Drag blocks here to build your storefront layout</div>';
    return;
  }
  sections.forEach(function(s, i) {
    var el = document.createElement('div');
    el.className = 'layout-section';
    el.draggable = true;
    el.dataset.index = i;
    el.innerHTML = '<div class="layout-section-header">' +
      '<span class="layout-section-drag"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 8h16M4 16h16"/></svg></span>' +
      '<span class="layout-section-name">' + (blockLabels[s] || s) + '</span>' +
      '<button class="layout-section-remove" onclick="removeSection(' + i + ')" title="Remove">&times;</button>' +
    '</div>' +
    '<div class="layout-section-preview">' + (blockPreviews[s] || '') + '</div>';

    el.addEventListener('dragstart', function(e) {
      dragSrcEl = el;
      el.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    el.addEventListener('dragend', function() {
      el.classList.remove('dragging');
      document.querySelectorAll('.drag-over-item').forEach(function(x) { x.classList.remove('drag-over-item'); });
    });
    el.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      el.classList.add('drag-over-item');
    });
    el.addEventListener('dragleave', function() { el.classList.remove('drag-over-item'); });
    el.addEventListener('drop', function(e) {
      e.preventDefault();
      el.classList.remove('drag-over-item');
      if (dragSrcEl && dragSrcEl !== el) {
        var fromIdx = parseInt(dragSrcEl.dataset.index);
        var toIdx = parseInt(el.dataset.index);
        var moved = sections.splice(fromIdx, 1)[0];
        sections.splice(toIdx, 0, moved);
        renderSections();
      }
    });
    canvas.appendChild(el);
  });
}

function removeSection(idx) {
  sections.splice(idx, 1);
  renderSections();
}

function resetLayout() {
  sections = ['hero', 'featured-products', 'collections-grid', 'brand-story', 'newsletter'];
  renderSections();
  showToast('Layout reset to default', 'info');
}

function saveLayout() {
  fetch('/admin/layout/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ sections: sections })
  }).then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.ok) showToast('Layout saved and published!', 'success');
    else showToast('Error saving layout', 'error');
  }).catch(function() { showToast('Error saving layout', 'error'); });
}

// Handle drag from blocks panel to canvas
document.querySelectorAll('.layout-block-item').forEach(function(block) {
  block.addEventListener('dragstart', function(e) {
    e.dataTransfer.setData('text/plain', block.dataset.block);
    e.dataTransfer.effectAllowed = 'copy';
  });
});

canvas.addEventListener('dragover', function(e) {
  e.preventDefault();
  canvas.classList.add('drag-over');
});
canvas.addEventListener('dragleave', function() { canvas.classList.remove('drag-over'); });
canvas.addEventListener('drop', function(e) {
  e.preventDefault();
  canvas.classList.remove('drag-over');
  var blockType = e.dataTransfer.getData('text/plain');
  if (blockType && blockLabels[blockType]) {
    sections.push(blockType);
    renderSections();
  }
});

renderSections();
</script>
