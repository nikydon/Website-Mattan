    </div>
  </div>
</div>

<!-- Keyboard Shortcuts Modal -->
<div class="le-modal-overlay" id="shortcutsModal" style="display:none;">
  <div class="le-modal">
    <div class="le-modal-header">
      <h3>Keyboard Shortcuts</h3>
      <button class="le-modal-close" onclick="document.getElementById('shortcutsModal').style.display='none'">&times;</button>
