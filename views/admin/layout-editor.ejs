  ]
};

// ═══════════════════════════════════════════════════════
// SECTION LIST (LEFT PANEL)
// ═══════════════════════════════════════════════════════
var sectionList = document.getElementById('sectionList');
var dragSrcEl = null;

function getVisKey(section, idx) {
  return section + '-' + idx;
}

function renderSectionList() {
  sectionList.innerHTML = '';
  if (sections.length === 0) {
    sectionList.innerHTML = '<div class="le-empty-msg">Drag components from the library to add sections.</div>';
    return;
  }
  sections.forEach(function(s, i) {
    var vk = getVisKey(s, i);
    var vis = sectionVisibility[vk] || {};
    var isHidden = vis.hidden;
    var isSelected = selectedIdx === i;

    var el = document.createElement('div');
    el.className = 'le-section-item' + (isSelected ? ' selected' : '') + (isHidden ? ' hidden-section' : '');
    el.draggable = true;
    el.dataset.index = i;

    el.innerHTML =
      '<span class="le-section-drag"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 8h16M4 16h16"/></svg></span>' +
      '<span class="le-section-label">' + (blockLabels[s] || s) + '</span>' +
      '<div class="le-section-btns">' +
        '<button class="le-icon-btn' + (isHidden ? ' le-toggled-off' : '') + '" onclick="toggleVisibility(' + i + ', event)" title="' + (isHidden ? 'Show' : 'Hide') + '">' +
          (isHidden ? '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M3 3l18 18"/></svg>'
                    : '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>') +
        '</button>' +
        '<button class="le-icon-btn le-remove-btn" onclick="removeSection(' + i + ', event)" title="Remove">' +
          '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
        '</button>' +
      '</div>';

    el.addEventListener('click', function(e) {
      if (e.target.closest('.le-icon-btn')) return;
      selectSection(i);
    });

    // Drag events for reordering
    el.addEventListener('dragstart', function(e) {
      dragSrcEl = el;
      el.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', '');
    });
    el.addEventListener('dragend', function() {
      el.classList.remove('dragging');
      document.querySelectorAll('.le-section-item.drag-over').forEach(function(x) { x.classList.remove('drag-over'); });
    });
    el.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      el.classList.add('drag-over');
    });
    el.addEventListener('dragleave', function() { el.classList.remove('drag-over'); });
    el.addEventListener('drop', function(e) {
      e.preventDefault();
      e.stopPropagation();
      el.classList.remove('drag-over');
      // Check if from component panel
      var blockType = e.dataTransfer.getData('block-type');
      if (blockType) {
        sections.splice(i, 0, blockType);
        selectedIdx = i;
        renderSectionList();
        refreshPreview();
        return;
      }
      if (dragSrcEl && dragSrcEl !== el) {
        var fromIdx = parseInt(dragSrcEl.dataset.index);
        var toIdx = parseInt(el.dataset.index);
        // Remap styles/visibility keys
        remapKeys(fromIdx, toIdx);
        var moved = sections.splice(fromIdx, 1)[0];
        sections.splice(toIdx, 0, moved);
        if (selectedIdx === fromIdx) selectedIdx = toIdx;
        else if (selectedIdx === toIdx) selectedIdx = fromIdx;
        renderSectionList();
        refreshPreview();
      }
    });

    sectionList.appendChild(el);
  });
}

function remapKeys(fromIdx, toIdx) {
  // Remap style/visibility keys when sections are reordered
  var newStyles = {};
  var newVis = {};
  sections.forEach(function(s, i) {
    var oldKey = getVisKey(s, i);
    var newI = i;
    if (i === fromIdx) newI = toIdx;
    else if (fromIdx < toIdx && i > fromIdx && i <= toIdx) newI = i - 1;
    else if (fromIdx > toIdx && i >= toIdx && i < fromIdx) newI = i + 1;
    var newKey = getVisKey(s, newI);
    if (sectionStyles[oldKey]) newStyles[newKey] = sectionStyles[oldKey];
    if (sectionVisibility[oldKey]) newVis[newKey] = sectionVisibility[oldKey];
  });
  sectionStyles = newStyles;
  sectionVisibility = newVis;
}

// Drop zone for section list (catch drops from component library)
sectionList.addEventListener('dragover', function(e) { e.preventDefault(); });
sectionList.addEventListener('drop', function(e) {
  e.preventDefault();
  var blockType = e.dataTransfer.getData('block-type');
  if (blockType && blockLabels[blockType]) {
    sections.push(blockType);
    selectedIdx = sections.length - 1;
    renderSectionList();
    refreshPreview();
  }
});

function selectSection(idx) {
  selectedIdx = idx;
  renderSectionList();
  renderContentPanel();
  renderStylePanel();
}

function toggleVisibility(idx, e) {
  e.stopPropagation();
  var vk = getVisKey(sections[idx], idx);
  if (!sectionVisibility[vk]) sectionVisibility[vk] = {};
  sectionVisibility[vk].hidden = !sectionVisibility[vk].hidden;
  renderSectionList();
  refreshPreview();
}

function removeSection(idx, e) {
  e.stopPropagation();
  var vk = getVisKey(sections[idx], idx);
  delete sectionStyles[vk];
  delete sectionVisibility[vk];
  sections.splice(idx, 1);
  if (selectedIdx === idx) { selectedIdx = -1; renderContentPanel(); renderStylePanel(); }
  else if (selectedIdx > idx) selectedIdx--;
  renderSectionList();
  refreshPreview();
}

// ═══════════════════════════════════════════════════════
// CONTENT PANEL (RIGHT)
// ═══════════════════════════════════════════════════════
function renderContentPanel() {
  var noSel = document.getElementById('contentNoSelection');
  var fields = document.getElementById('contentEditFields');
  if (selectedIdx < 0 || selectedIdx >= sections.length) {
    noSel.style.display = '';
    fields.style.display = 'none';
    return;
  }
  noSel.style.display = 'none';
  fields.style.display = '';

  var s = sections[selectedIdx];
  var content = sectionContent[s] || {};
  var defs = blockFields[s] || [];

  var html = '<h3 class="le-props-title">' + (blockLabels[s] || s) + '</h3>';
  if (defs.length === 0) {
    html += '<p class="le-props-note">This section has no editable content fields.</p>';
  } else {
    defs.forEach(function(f) {
      var val = content[f.key] || '';
      html += '<div class="le-field">';
      html += '<label class="le-field-label">' + f.label + '</label>';
      if (f.type === 'textarea') {
        html += '<textarea class="le-field-input" data-section="' + s + '" data-key="' + f.key + '" placeholder="' + f.placeholder + '" rows="4">' + val + '</textarea>';
      } else {
        html += '<input type="text" class="le-field-input" data-section="' + s + '" data-key="' + f.key + '" value="' + val.replace(/"/g, '&quot;') + '" placeholder="' + f.placeholder + '">';
      }
      html += '</div>';
    });
  }
  fields.innerHTML = html;

  // Attach input handlers
  fields.querySelectorAll('.le-field-input').forEach(function(input) {
    input.addEventListener('input', function() {
      var sec = this.dataset.section;
      var key = this.dataset.key;
      if (!sectionContent[sec]) sectionContent[sec] = {};
      sectionContent[sec][key] = this.value;
      debouncedPreview();
    });
  });
}

// ═══════════════════════════════════════════════════════
// STYLE PANEL (RIGHT)
// ═══════════════════════════════════════════════════════
function renderStylePanel() {
  var noSel = document.getElementById('styleNoSelection');
  var fields = document.getElementById('styleEditFields');
  if (selectedIdx < 0 || selectedIdx >= sections.length) {
    noSel.style.display = '';
    fields.style.display = 'none';
    return;
  }
  noSel.style.display = 'none';
  fields.style.display = '';

  var s = sections[selectedIdx];
  var vk = getVisKey(s, selectedIdx);
  var st = sectionStyles[vk] || {};

  var html = '<h3 class="le-props-title">Style: ' + (blockLabels[s] || s) + '</h3>';

  // Background color
  html += '<div class="le-field"><label class="le-field-label">Background Color</label>' +
    '<div class="le-color-row"><input type="color" class="le-color-picker" data-style-key="bgColor" value="' + (st.bgColor || '#ffffff') + '">' +
    '<input type="text" class="le-field-input le-field-sm" data-style-key="bgColor" value="' + (st.bgColor || '') + '" placeholder="#ffffff"></div></div>';

  // Text color
  html += '<div class="le-field"><label class="le-field-label">Text Color</label>' +
    '<div class="le-color-row"><input type="color" class="le-color-picker" data-style-key="textColor" value="' + (st.textColor || '#1a1a1a') + '">' +
    '<input type="text" class="le-field-input le-field-sm" data-style-key="textColor" value="' + (st.textColor || '') + '" placeholder="#1a1a1a"></div></div>';

  // Font family
  html += '<div class="le-field"><label class="le-field-label">Font Family</label>' +
    '<select class="le-field-select" data-style-key="fontFamily">' +
    '<option value="">Default</option>' +
    '<option value="Inter"' + (st.fontFamily === 'Inter' ? ' selected' : '') + '>Inter</option>' +
    '<option value="Georgia"' + (st.fontFamily === 'Georgia' ? ' selected' : '') + '>Georgia</option>' +
    '<option value="Playfair Display"' + (st.fontFamily === 'Playfair Display' ? ' selected' : '') + '>Playfair Display</option>' +
    '<option value="Roboto"' + (st.fontFamily === 'Roboto' ? ' selected' : '') + '>Roboto</option>' +
    '<option value="Montserrat"' + (st.fontFamily === 'Montserrat' ? ' selected' : '') + '>Montserrat</option>' +
    '<option value="Lora"' + (st.fontFamily === 'Lora' ? ' selected' : '') + '>Lora</option>' +
    '</select></div>';

  // Font size
  html += '<div class="le-field"><label class="le-field-label">Font Size (px)</label>' +
    '<input type="number" class="le-field-input" data-style-key="fontSize" value="' + (st.fontSize || '') + '" placeholder="16" min="10" max="72"></div>';

  // Padding
  html += '<div class="le-field-row">' +
    '<div class="le-field"><label class="le-field-label">Padding Top (px)</label>' +
    '<input type="number" class="le-field-input" data-style-key="paddingTop" value="' + (st.paddingTop || '') + '" placeholder="64" min="0" max="300"></div>' +
    '<div class="le-field"><label class="le-field-label">Padding Bottom (px)</label>' +
    '<input type="number" class="le-field-input" data-style-key="paddingBottom" value="' + (st.paddingBottom || '') + '" placeholder="64" min="0" max="300"></div>' +
    '</div>';

  // Background image
  html += '<div class="le-field"><label class="le-field-label">Background Image URL</label>' +
    '<input type="text" class="le-field-input" data-style-key="bgImage" value="' + (st.bgImage || '') + '" placeholder="/uploads/bg.jpg"></div>';

  // Reset styles button
  html += '<button class="btn btn--small" onclick="resetSectionStyle()" style="margin-top:1rem;">Reset Styles</button>';

  fields.innerHTML = html;

  // Attach style handlers
  fields.querySelectorAll('[data-style-key]').forEach(function(input) {
    var evName = (input.type === 'color') ? 'input' : 'change';
    input.addEventListener('input', function() {
      updateStyleValue(this);
    });
    if (evName === 'change') {
      input.addEventListener('change', function() {
        updateStyleValue(this);
      });
    }
  });
}

function updateStyleValue(input) {
  var key = input.dataset.styleKey;
  var vk = getVisKey(sections[selectedIdx], selectedIdx);
  if (!sectionStyles[vk]) sectionStyles[vk] = {};

  var val = input.value;
  if (val === '' || val === undefined) {
    delete sectionStyles[vk][key];
  } else {
    sectionStyles[vk][key] = val;
  }

  // Sync color picker and text input
  var container = input.closest('.le-color-row');
  if (container) {
    container.querySelectorAll('[data-style-key="' + key + '"]').forEach(function(el) {
      if (el !== input) el.value = val;
    });
  }

  debouncedPreview();
}

function resetSectionStyle() {
  if (selectedIdx < 0) return;
  var vk = getVisKey(sections[selectedIdx], selectedIdx);
  delete sectionStyles[vk];
  renderStylePanel();
  refreshPreview();
}

// ═══════════════════════════════════════════════════════
// LIVE PREVIEW
// ═══════════════════════════════════════════════════════
function refreshPreview() {
  document.getElementById('previewLoading').style.display = 'flex';
  fetch('/admin/layout/preview', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      sections: sections,
      content: sectionContent,
      styles: sectionStyles,
      visibility: sectionVisibility
    })
  }).then(function(r) { return r.text(); })
  .then(function(html) {
    var frame = document.getElementById('previewFrame');
    frame.srcdoc = html;
    frame.onload = function() {
      document.getElementById('previewLoading').style.display = 'none';
    };
  }).catch(function() {
    document.getElementById('previewLoading').style.display = 'none';
  });
}

function debouncedPreview() {
  clearTimeout(previewDebounce);
  previewDebounce = setTimeout(refreshPreview, 600);
}

// ═══════════════════════════════════════════════════════
// RESPONSIVE PREVIEW
// ═══════════════════════════════════════════════════════
document.querySelectorAll('.le-device-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.le-device-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    var device = btn.dataset.device;
    var wrapper = document.getElementById('previewFrameWrapper');
    wrapper.className = 'le-preview-frame-wrapper le-device-' + device;
  });
});

// ═══════════════════════════════════════════════════════
// PANEL TABS
// ═══════════════════════════════════════════════════════
document.querySelectorAll('.le-panel-tabs').forEach(function(tabs) {
  tabs.querySelectorAll('.le-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var parent = tab.closest('.le-left-panel, .le-right-panel');
      parent.querySelectorAll('.le-tab').forEach(function(t) { t.classList.remove('active'); });
      parent.querySelectorAll('.le-tab-content').forEach(function(c) { c.classList.remove('active'); });
      tab.classList.add('active');
      var target = document.getElementById('tab-' + tab.dataset.tab);
      if (target) target.classList.add('active');
    });
  });
});

// ═══════════════════════════════════════════════════════
// COMPONENT LIBRARY DRAG
// ═══════════════════════════════════════════════════════
document.querySelectorAll('.le-comp-item').forEach(function(item) {
  item.addEventListener('dragstart', function(e) {
    e.dataTransfer.setData('block-type', item.dataset.block);
    e.dataTransfer.effectAllowed = 'copy';
  });
});

// Also allow drop on the preview area to add sections
var previewArea = document.getElementById('lePreviewArea');
previewArea.addEventListener('dragover', function(e) { e.preventDefault(); });
previewArea.addEventListener('drop', function(e) {
  e.preventDefault();
  var blockType = e.dataTransfer.getData('block-type');
  if (blockType && blockLabels[blockType]) {
    sections.push(blockType);
    selectedIdx = sections.length - 1;
    renderSectionList();
    renderContentPanel();
    renderStylePanel();
    refreshPreview();
  }
});

// ═══════════════════════════════════════════════════════
// SAVE / PUBLISH / DISCARD
// ═══════════════════════════════════════════════════════
function saveDraft() {
  fetch('/admin/layout/save-draft', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ sections: sections, content: sectionContent, styles: sectionStyles, visibility: sectionVisibility })
  }).then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.ok) showToast('Draft saved!', 'success');
    else showToast('Error saving draft', 'error');
  }).catch(function() { showToast('Error saving draft', 'error'); });
}

function publishLayout() {
  fetch('/admin/layout/publish', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ sections: sections, content: sectionContent, styles: sectionStyles, visibility: sectionVisibility })
  }).then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.ok) showToast('Layout published to live site!', 'success');
    else showToast('Error publishing layout', 'error');
  }).catch(function() { showToast('Error publishing layout', 'error'); });
}

function discardDraft() {
  if (!confirm('Discard all unsaved changes and revert to the published layout?')) return;
  fetch('/admin/layout/discard-draft', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  }).then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.ok) {
      showToast('Draft discarded', 'info');
      window.location.reload();
    }
  }).catch(function() { showToast('Error discarding draft', 'error'); });
}

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════
renderSectionList();
refreshPreview();
</script>
