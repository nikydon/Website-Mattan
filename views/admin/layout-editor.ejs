<script>
// ═══════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════
var sections = <%- JSON.stringify(sections) %>;
var sectionContent = <%- JSON.stringify(sectionContent) %>;
var sectionStyles = <%- JSON.stringify(sectionStyles) %>;
var sectionVisibility = <%- JSON.stringify(sectionVisibility) %>;
var selectedIdx = -1;
var previewDebounce = null;
var zoomLevel = 100;
var imageUploadCallback = null;

// Undo/Redo history
var historyStack = [];
var historyIdx = -1;
var maxHistory = 50;

function cloneState() {
  return {
    sections: JSON.parse(JSON.stringify(sections)),
    sectionContent: JSON.parse(JSON.stringify(sectionContent)),
    sectionStyles: JSON.parse(JSON.stringify(sectionStyles)),
    sectionVisibility: JSON.parse(JSON.stringify(sectionVisibility)),
    selectedIdx: selectedIdx
  };
}

function pushHistory() {
  historyIdx++;
  historyStack = historyStack.slice(0, historyIdx);
  historyStack.push(cloneState());
  if (historyStack.length > maxHistory) {
    historyStack.shift();
    historyIdx--;
  }
  updateHistoryBtns();
}

function undo() {
  if (historyIdx <= 0) return;
  historyIdx--;
  restoreState(historyStack[historyIdx]);
}

function redo() {
  if (historyIdx >= historyStack.length - 1) return;
  historyIdx++;
  restoreState(historyStack[historyIdx]);
}

function restoreState(state) {
  sections = JSON.parse(JSON.stringify(state.sections));
  sectionContent = JSON.parse(JSON.stringify(state.sectionContent));
  sectionStyles = JSON.parse(JSON.stringify(state.sectionStyles));
  sectionVisibility = JSON.parse(JSON.stringify(state.sectionVisibility));
  selectedIdx = state.selectedIdx;
  renderSectionList();
  renderContentPanel();
  renderStylePanel();
  refreshPreview();
  updateHistoryBtns();
}

function updateHistoryBtns() {
  document.getElementById('undoBtn').disabled = historyIdx <= 0;
  document.getElementById('redoBtn').disabled = historyIdx >= historyStack.length - 1;
}

// Initialize history with initial state
pushHistory();

var blockLabels = {
  'hero': 'Hero Banner', 'featured-products': 'Featured Products', 'collections-grid': 'Collections Grid',
  'banner': 'Image Banner', 'text-block': 'Text Block', 'newsletter': 'Newsletter Signup',
