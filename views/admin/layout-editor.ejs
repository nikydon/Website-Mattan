<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main le-fullscreen">
  <!-- Top Toolbar -->
  <div class="le-toolbar">
    <div class="le-toolbar-left">
      <a href="/admin" class="le-back-btn">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
      </a>
      <h1 class="le-toolbar-title">Layout Editor</h1>
      <% if (hasDraft) { %>
        <span class="le-draft-badge">Draft</span>
      <% } %>
    </div>
    <div class="le-toolbar-center">
      <!-- Responsive Preview Controls -->
      <div class="le-device-switcher">
        <button class="le-device-btn active" data-device="desktop" title="Desktop">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
        </button>
        <button class="le-device-btn" data-device="tablet" title="Tablet">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M12 18h.01"/></svg>
        </button>
        <button class="le-device-btn" data-device="mobile" title="Mobile">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
        </button>
      </div>
    </div>
    <div class="le-toolbar-right">
      <button class="btn" onclick="discardDraft()">Discard</button>
      <button class="btn" onclick="saveDraft()">Save Draft</button>
      <button class="btn btn--primary" onclick="publishLayout()">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
        Publish
      </button>
    </div>
  </div>

  <div class="le-workspace">
    <!-- Left Panel: Components + Sections -->
    <div class="le-left-panel" id="leLeftPanel">
      <div class="le-panel-tabs">
        <button class="le-tab active" data-tab="sections">Sections</button>
        <button class="le-tab" data-tab="components">Components</button>
      </div>

      <!-- Sections Tab: Current Layout -->
      <div class="le-tab-content active" id="tab-sections">
        <div class="le-section-list" id="sectionList"></div>
      </div>

      <!-- Components Tab: Drag-and-Drop Library -->
      <div class="le-tab-content" id="tab-components">
        <div class="le-component-group">
          <h4 class="le-group-title">Content</h4>
          <div class="le-comp-item" draggable="true" data-block="hero">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5z"/></svg>
            <div><strong>Hero Banner</strong><small>Full-width hero with CTA</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="text-block">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
            <div><strong>Text Block</strong><small>Rich text content area</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="banner">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <div><strong>Image Banner</strong><small>Promotional banner with image</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="video">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <div><strong>Video</strong><small>YouTube, Vimeo, or direct</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="cta-strip">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <div><strong>CTA Strip</strong><small>Call-to-action bar</small></div>
          </div>
        </div>

        <div class="le-component-group">
          <h4 class="le-group-title">Commerce</h4>
          <div class="le-comp-item" draggable="true" data-block="featured-products">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            <div><strong>Featured Products</strong><small>Product showcase grid</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="collections-grid">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            <div><strong>Collections Grid</strong><small>Browse all collections</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="countdown">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <div><strong>Countdown</strong><small>Timer for launches/sales</small></div>
          </div>
        </div>

        <div class="le-component-group">
          <h4 class="le-group-title">Social Proof</h4>
          <div class="le-comp-item" draggable="true" data-block="testimonials">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            <div><strong>Testimonials</strong><small>Customer reviews</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="logo-bar">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <div><strong>Logo Bar</strong><small>Partner/press logos</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="social-feed">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/></svg>
            <div><strong>Social Links</strong><small>Instagram, TikTok links</small></div>
          </div>
        </div>

        <div class="le-component-group">
          <h4 class="le-group-title">Layout & Info</h4>
          <div class="le-comp-item" draggable="true" data-block="brand-story">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            <div><strong>Brand Story</strong><small>About your brand</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="newsletter">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <div><strong>Newsletter</strong><small>Email signup form</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="news-feed">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"/></svg>
            <div><strong>News Feed</strong><small>Latest news posts</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="faq">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg>
            <div><strong>FAQ</strong><small>Questions &amp; answers</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="gallery">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            <div><strong>Gallery</strong><small>Image grid gallery</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="features-grid">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            <div><strong>Features Grid</strong><small>Feature highlights</small></div>
          </div>
          <div class="le-comp-item" draggable="true" data-block="divider">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14"/></svg>
            <div><strong>Divider</strong><small>Visual separator</small></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Center: Live Preview -->
    <div class="le-preview-area" id="lePreviewArea">
      <div class="le-preview-frame-wrapper" id="previewFrameWrapper">
        <iframe id="previewFrame" class="le-preview-frame" sandbox="allow-same-origin allow-scripts"></iframe>
        <div class="le-preview-loading" id="previewLoading">
          <div class="le-spinner"></div>
          <span>Loading preview...</span>
        </div>
      </div>
    </div>

    <!-- Right Panel: Properties/Styles -->
    <div class="le-right-panel" id="leRightPanel">
      <div class="le-panel-tabs">
        <button class="le-tab active" data-tab="content-edit">Content</button>
        <button class="le-tab" data-tab="style-edit">Style</button>
      </div>

      <div class="le-tab-content active" id="tab-content-edit">
        <div class="le-no-selection" id="contentNoSelection">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/></svg>
          <p>Select a section from the left panel to edit its content.</p>
        </div>
        <div id="contentEditFields" style="display:none;"></div>
      </div>

      <div class="le-tab-content" id="tab-style-edit">
        <div class="le-no-selection" id="styleNoSelection">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          <p>Select a section to adjust its styling.</p>
        </div>
        <div id="styleEditFields" style="display:none;"></div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
// ═══════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════
var sections = <%- JSON.stringify(sections) %>;
var sectionContent = <%- JSON.stringify(sectionContent) %>;
var sectionStyles = <%- JSON.stringify(sectionStyles) %>;
var sectionVisibility = <%- JSON.stringify(sectionVisibility) %>;
var selectedIdx = -1;
var previewDebounce = null;

