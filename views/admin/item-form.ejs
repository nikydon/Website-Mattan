<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <div class="breadcrumbs">
    <a href="/admin">Dashboard</a>
    <span class="sep">/</span>
    <a href="/admin/items">Products</a>
    <span class="sep">/</span>
    <span class="current"><%= isEdit ? item.title : 'New Product' %></span>
  </div>

  <h1 class="admin-page-title"><%= isEdit ? 'Edit' : 'New' %> Product</h1>

  <form method="POST" action="<%= isEdit ? '/admin/items/' + item.id + '/edit' : '/admin/items/new' %>" class="admin-form">
    <div class="form-row">
      <div>
        <label class="form-label" for="title">Title</label>
        <input class="form-input" type="text" id="title" name="title" value="<%= isEdit ? item.title : '' %>" required>
      </div>
      <div>
        <label class="form-label" for="slug">Slug</label>
        <input class="form-input" type="text" id="slug" name="slug" value="<%= isEdit ? item.slug : '' %>" required>
      </div>
    </div>

    <label class="form-label" for="collectionId">Collection</label>
    <select class="form-input" id="collectionId" name="collectionId">
      <option value="">- None -</option>
      <% collections.forEach(function(col) { %>
        <option value="<%= col.id %>" <%= isEdit && item.collectionId === col.id ? 'selected' : '' %>><%= col.name %></option>
      <% }); %>
    </select>

    <label class="form-label" for="description">Description</label>
    <textarea class="form-input form-textarea" id="description" name="description" rows="3"><%= isEdit && item.description ? item.description : '' %></textarea>

    <div class="form-row">
      <div>
        <label class="form-label" for="price">Price</label>
        <input class="form-input" type="text" id="price" name="price" value="<%= isEdit && item.price ? item.price : '' %>" placeholder="e.g. 320">
      </div>
      <div>
        <label class="form-label" for="stockQty">Stock Quantity</label>
        <input class="form-input" type="number" id="stockQty" name="stockQty" value="<%= isEdit ? item.stockQty : 0 %>" min="0">
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="form-label" for="materials">Materials</label>
        <input class="form-input" type="text" id="materials" name="materials" value="<%= isEdit && item.materials ? item.materials : '' %>">
      </div>
      <div>
        <label class="form-label" for="tags">Tags</label>
        <input class="form-input" type="text" id="tags" name="tags" value="<%= isEdit && item.tags ? item.tags : '' %>" placeholder="gold, ring, minimal">
        <span class="form-hint">Comma-separated</span>
      </div>
    </div>

    <label class="form-label" for="sortOrder">Sort Order</label>
    <input class="form-input" type="number" id="sortOrder" name="sortOrder" value="<%= isEdit ? item.sortOrder : 0 %>" style="max-width:120px">

    <label class="form-checkbox">
      <input type="checkbox" name="published" value="true" <%= isEdit && item.published ? 'checked' : '' %>>
      Published
    </label>

    <div class="form-actions">
      <button class="btn btn--primary" type="submit">Save Product</button>
      <a href="/admin/items" class="btn">Cancel</a>
    </div>
  </form>

  <% if (isEdit) { %>
  <hr class="admin-divider">
  <h2 class="admin-section-title">Media (Photos & Videos)</h2>

  <div class="image-grid">
    <% item.images.forEach(function(img) { %>
    <div class="image-card">
      <% if (img.mediaType === 'video') { %>
        <div class="media-thumb media-thumb--video">
          <video src="/uploads/full/<%= img.filename %>" muted preload="metadata"></video>
          <span class="media-badge">VIDEO</span>
        </div>
      <% } else { %>
        <img src="/uploads/thumbs/<%= img.filename.replace(/\.\w+$/, '.webp') %>" alt="<%= img.altText || item.title %>">
      <% } %>
      <form method="POST" action="/admin/items/<%= item.id %>/images/<%= img.id %>/delete" class="image-delete-form" onsubmit="return confirmDelete(this, 'Remove Media', 'Delete this file?')">
        <button type="submit" class="btn btn--danger btn--small">Remove</button>
      </form>
    </div>
    <% }); %>
  </div>

  <form method="POST" action="/admin/items/<%= item.id %>/images" enctype="multipart/form-data" class="admin-form upload-form">
    <label class="form-label" for="file">Add Photo or Video</label>
    <input class="form-input" type="file" id="file" name="file" accept="image/*,video/mp4,video/webm,video/quicktime" required>
    <label class="form-label" for="altText">Alt Text / Caption</label>
    <input class="form-input" type="text" id="altText" name="altText" placeholder="Describe the media">
    <button class="btn btn--primary" type="submit" style="margin-top:0.75rem">Upload</button>
  </form>
  <% } %>
</div>

<%- include('partials/footer') %>
