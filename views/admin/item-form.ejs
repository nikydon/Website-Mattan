<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-main">
  <h1 class="admin-page-title"><%= isEdit ? 'Edit' : 'New' %> Catalog Item</h1>

  <form method="POST" action="<%= isEdit ? '/admin/items/' + item.id + '/edit' : '/admin/items/new' %>" class="admin-form">
    <label class="form-label" for="title">Title</label>
    <input class="form-input" type="text" id="title" name="title" value="<%= isEdit ? item.title : '' %>" required>

    <label class="form-label" for="slug">Slug</label>
    <input class="form-input" type="text" id="slug" name="slug" value="<%= isEdit ? item.slug : '' %>" required>

    <label class="form-label" for="collectionId">Collection</label>
    <select class="form-input" id="collectionId" name="collectionId">
      <option value="">— None —</option>
      <% collections.forEach(col => { %>
        <option value="<%= col.id %>" <%= isEdit && item.collectionId === col.id ? 'selected' : '' %>><%= col.name %></option>
      <% }) %>
    </select>

    <label class="form-label" for="description">Description</label>
    <textarea class="form-input form-textarea" id="description" name="description" rows="3"><%= isEdit && item.description ? item.description : '' %></textarea>

    <label class="form-label" for="price">Price</label>
    <input class="form-input" type="text" id="price" name="price" value="<%= isEdit && item.price ? item.price : '' %>" placeholder="e.g. €320">

    <label class="form-label" for="materials">Materials</label>
    <input class="form-input" type="text" id="materials" name="materials" value="<%= isEdit && item.materials ? item.materials : '' %>">

    <label class="form-label" for="sortOrder">Sort Order</label>
    <input class="form-input" type="number" id="sortOrder" name="sortOrder" value="<%= isEdit ? item.sortOrder : 0 %>">

    <label class="form-checkbox">
      <input type="checkbox" name="published" value="true" <%= isEdit && item.published ? 'checked' : '' %>>
      Published
    </label>

    <div class="form-actions">
      <button class="btn btn--primary" type="submit">Save</button>
      <a href="/admin/items" class="btn">Cancel</a>
    </div>
  </form>

  <% if (isEdit) { %>
  <hr class="admin-divider">
  <h2 class="admin-section-title">Images</h2>

  <div class="image-grid">
    <% item.images.forEach(img => { %>
    <div class="image-card">
      <img src="/uploads/thumbs/<%= img.filename.replace(/\.\w+$/, '.webp') %>" alt="<%= img.altText || item.title %>">
      <form method="POST" action="/admin/items/<%= item.id %>/images/<%= img.id %>/delete" class="image-delete-form">
        <button type="submit" class="btn btn--danger btn--small" onclick="return confirm('Delete this image?')">Remove</button>
      </form>
    </div>
    <% }) %>
  </div>

  <form method="POST" action="/admin/items/<%= item.id %>/images" enctype="multipart/form-data" class="admin-form upload-form">
    <label class="form-label" for="file">Add Image</label>
    <input class="form-input" type="file" id="file" name="file" accept="image/*" required>
    <label class="form-label" for="altText">Alt Text</label>
    <input class="form-input" type="text" id="altText" name="altText" placeholder="Describe the image">
    <button class="btn btn--primary" type="submit">Upload</button>
  </form>
  <% } %>
</div>

<%- include('partials/footer') %>
