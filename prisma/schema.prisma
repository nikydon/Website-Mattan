generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant ──────────────────────────────────────────────
// One row per brand/site. Every other table references this.
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  collections  Collection[]
  catalogItems CatalogItem[]
  images       Image[]
  newsPosts    NewsPost[]
  siteSettings SiteSetting[]

  @@map("tenants")
}

// ─── Collection ──────────────────────────────────────────
// A group of jewelry pieces, e.g. "Rings", "Earrings".
model Collection {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  catalogItems CatalogItem[]

  @@unique([tenantId, slug])
  @@map("collections")
}

// ─── CatalogItem ─────────────────────────────────────────
// A single jewelry piece.
model CatalogItem {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  collectionId String?  @map("collection_id")
  title        String
  slug         String
  description  String?
  price        String?
  materials    String?
  sortOrder    Int      @default(0) @map("sort_order")
  published    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])
  images     Image[]

  @@unique([tenantId, slug])
  @@map("catalog_items")
}

// ─── Image ───────────────────────────────────────────────
// An uploaded image. Can be linked to a catalog item, news post, or standalone.
model Image {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  filename      String
  originalName  String   @map("original_name")
  altText       String?  @map("alt_text")
  category      String   @default("catalog")
  catalogItemId String?  @map("catalog_item_id")
  newsPostId    String?  @map("news_post_id")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id])
  newsPost    NewsPost?    @relation(fields: [newsPostId], references: [id])

  @@map("images")
}

// ─── NewsPost ────────────────────────────────────────────
// A news article or update.
model NewsPost {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  title       String
  slug        String
  body        String
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  images Image[]

  @@unique([tenantId, slug])
  @@map("news_posts")
}

// ─── SiteSetting ─────────────────────────────────────────
// Key-value pairs for editable text: brand story, about page, etc.
model SiteSetting {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  key      String
  value    String

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("site_settings")
}
